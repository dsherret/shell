{
  "name": "@david/shell",
  "nodeModulesDir": "none",
  "test": {
    "permissions": {
      "all": true
    }
  },
  "tasks": {
    "test": "deno test -P && deno task test:node",
    "test:node": "unset FORCE_COLOR && npx --yes github:dsherret/deno-test#fix_work_on_windows",
    "wasmbuild": "deno run -A jsr:@deno/wasmbuild@0.19.2 --inline --out ./src/lib"
  },
  "fmt": {
    "proseWrap": "preserve",
    "operatorPosition": "nextLine",
    "lineWidth": 120
  },
  "lint": {
    "rules": {
      "exclude": ["ban-types", "no-explicit-any", "no-this-alias", "no-process-global"],
      "include": [
        "no-console",
        "no-sync-fn-in-async-fn"
      ]
    }
  },
  "exclude": [
    ".gitattributes",
    ".gitignore",
    ".github",
    ".rustfmt.toml",
    ".vscode",
    "Cargo.toml",
    "Cargo.lock",
    "target/",
    "src/rs_lib",
    "src/test",
    "dprint.json",
    "**/*.test.*"
  ],
  "exports": {
    ".": "./mod.ts",
    "./internal": "./internal.ts"
  },
  "imports": {
    "@david/console-static-text": "jsr:@david/console-static-text@^0.3.4",
    "@david/path": "jsr:@david/path@^0.3",
    "@david/temp": "jsr:@david/temp@^0.2.1",
    "@std/assert": "jsr:@std/assert@1",
    "@std/fmt": "jsr:@std/fmt@1",
    "@std/io": "jsr:@std/io@^0.225",
    "@std/path": "jsr:@std/path@1",
    "which": "jsr:@david/which@^0.6.0"
  }
}
